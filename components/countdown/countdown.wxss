/* countdown */

.cdown {
  background: linear-gradient(135deg, #FCFAF7, #F9F5EE);
  text-align: center; padding: 48rpx 36rpx;
  border-radius: 28rpx; margin: 32rpx 0;
  border: 1rpx solid rgba(196,155,138,0.06);
  box-shadow: var(--shadow-card);
}
.cd-rings { display: flex; justify-content: center; gap: 24rpx; align-items: center; flex-wrap: wrap; }
.cd-ring-item { text-align: center; position: relative; }
.cd-ring-item svg { width: 160rpx; height: 160rpx; transform: rotate(-90deg); }
.cd-bg { fill: none; stroke: rgba(0,0,0,0.03); stroke-width: 6; }
.cd-fg { fill: none; stroke-width: 6; stroke-linecap: round; transition: stroke-dashoffset 0.8s ease-out; }
.cd-fg.days { stroke: #E8A87C; }
.cd-fg.hours { stroke: #E0C068; }
.cd-fg.mins { stroke: #6DB58A; }
.cd-fg.secs { stroke: #988CB8; }
.cd-ring-label { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.cd-val { font-size: 46rpx; font-weight: 800; line-height: 1; color: var(--text); }
.cd-lbl { font-size: 22rpx; color: var(--muted); margin-top: 4rpx; letter-spacing: 4rpx; }
.cd-colon { font-size: 52rpx; font-weight: 300; color: var(--muted); opacity: 0.2; }
@media (max-width:500px){.cd-colon{display:none;}}
.cd-past { display: flex; flex-direction: column; align-items: center; padding: 28rpx 0; }
.cd-past-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #6DB58A; margin-bottom: 18rpx; opacity: 0.5; }
.cd-past-text { font-size: 30rpx; font-weight: 700; color: var(--text-secondary); }
