/* flight-card — 登机牌 */

.flight-card-wrapper { width: 100%; max-width: 680rpx; margin: 0 auto; }

.fc-tabs {
  display: flex;
  background: rgba(255,255,255,0.12);
  border-radius: 60rpx;
  padding: 6rpx; margin-bottom: 22rpx;
}
.fc-tab {
  flex: 1; text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx; font-weight: 600;
  color: rgba(255,255,255,0.6);
  border-radius: 60rpx;
  transition: all 0.25s ease-out;
}
.fc-tab.active {
  background: rgba(255,255,255,0.92);
  color: var(--text);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.flight-card {
  display: flex; flex-direction: column;
  background: linear-gradient(170deg, #FEFDFB, #FBFAF6);
  border-radius: 28rpx; overflow: hidden;
  box-shadow: 0 4rpx 28rpx rgba(0,0,0,0.1);
  transition: all 0.35s ease-out;
}

.bp-header {
  background: linear-gradient(135deg, #3D5040, #2E3D30);
  color: rgba(255,255,255,0.8);
  padding: 22rpx 40rpx;
  display: flex; align-items: center; justify-content: space-between;
}
.bp-label { font-size: 24rpx; letter-spacing: 8rpx; font-weight: 700; }

.bp-plane-icon {
  width: 24rpx; height: 24rpx;
  border-left: 5rpx solid rgba(255,255,255,0.5);
  border-top: 5rpx solid transparent;
  border-bottom: 5rpx solid transparent;
  border-radius: 2rpx; opacity: 0.5;
}

.bp-body {
  display: flex; align-items: center;
  padding: 40rpx 36rpx 24rpx;
}
.bp-station { text-align: center; flex: 1; min-width: 0; }
.bp-code {
  font-size: 68rpx; font-weight: 900;
  letter-spacing: 10rpx; color: var(--text); line-height: 1;
}
.bp-code.arr { color: var(--terracotta); }
.bp-city { font-size: 24rpx; color: var(--muted); margin-top: 4rpx; }
.bp-time {
  font-size: 52rpx; font-weight: 700;
  color: var(--text); margin-top: 20rpx;
  letter-spacing: 4rpx; line-height: 1;
}
.bp-date { font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }

.bp-route {
  display: flex; flex-direction: column; align-items: center;
  gap: 14rpx; padding: 0 24rpx; flex-shrink: 0;
}
.bp-route-visual { display: flex; align-items: center; gap: 0; }
.bp-dot {
  width: 14rpx; height: 14rpx;
  border-radius: 50%; background: var(--terracotta); flex-shrink: 0;
}
.bp-dash {
  width: 64rpx; height: 0;
  border-top: 4rpx dashed rgba(196,146,122,0.35);
}
.bp-plane-icon-sm {
  width: 28rpx; height: 28rpx;
  border-left: 6rpx solid rgba(196,146,122,0.5);
  border-top: 6rpx solid transparent;
  border-bottom: 6rpx solid transparent;
  border-radius: 3rpx; margin: 0 4rpx; flex-shrink: 0;
}
.bp-flight-no {
  font-size: 24rpx; font-weight: 700;
  color: var(--text); letter-spacing: 6rpx;
}
.bp-dur { font-size: 22rpx; color: var(--muted); }

.bp-info {
  display: flex; justify-content: space-around;
  padding: 10rpx 40rpx 0;
  font-size: 24rpx; color: var(--muted);
}
.bp-perf {
  border-top: 3rpx dotted rgba(0,0,0,0.06);
  margin: 22rpx 40rpx 0;
}
.bp-footer {
  padding: 22rpx 40rpx 32rpx;
  display: flex; justify-content: space-between; align-items: center;
  font-size: 24rpx; color: var(--muted);
}

.fextra {
  max-height: 0; overflow: hidden;
  transition: all 0.35s ease-out;
  font-size: 22rpx; color: var(--muted);
  text-align: center; padding: 0 40rpx; opacity: 0;
}
.flight-card.tapped .fextra {
  max-height: 80rpx; opacity: 1;
  padding: 4rpx 40rpx 24rpx;
}

/* 空状态 */
.flight-empty {
  display: flex; flex-direction: column; align-items: center;
  padding: 64rpx 40rpx;
  background: rgba(255,255,255,0.06);
  border-radius: 28rpx;
  border: 2rpx dashed rgba(255,255,255,0.15);
}
.fe-ring {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.2);
  margin-bottom: 24rpx; position: relative;
}
.fe-ring::after {
  content: '';
  position: absolute; top: 50%; left: 50%;
  width: 22rpx; height: 3rpx;
  background: rgba(255,255,255,0.35);
  border-radius: 2rpx;
  transform: translate(-50%,-50%) rotate(-25deg);
}
.fe-text { font-size: 26rpx; color: rgba(255,255,255,0.4); }
