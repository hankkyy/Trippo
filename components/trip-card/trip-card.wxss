/* trip-card */

.trip-card {
  position: relative; width: 100%; height: 460rpx;
  border-radius: 28rpx; overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.07);
  transition: all 0.35s ease-out;
}
.trip-card-hover { transform: scale(0.97); }
.trip-card-cover { position: absolute; inset: 0; background: #D8D4CC; }
.trip-card-overlay {
  position: absolute; inset: 0; z-index: 1; pointer-events: none;
  background: linear-gradient(180deg, rgba(40,38,32,0.06) 0%, rgba(30,28,22,0.02) 30%, rgba(15,12,8,0.55) 100%);
}
.trip-card-gradient {
  position: absolute; bottom: 0; left: 0; right: 0; height: 260rpx;
  background: linear-gradient(to top, rgba(15,12,8,0.6) 0%, rgba(15,12,8,0.2) 55%, transparent 100%);
  pointer-events: none; z-index: 1;
}
.trip-card-content { position: absolute; bottom: 36rpx; left: 36rpx; right: 36rpx; z-index: 3; }
.trip-dest-tag { margin-bottom: 12rpx; }
.trip-dest-tag text {
  font-size: 22rpx; color: rgba(255,255,255,0.7); letter-spacing: 3rpx; font-weight: 500;
  background: rgba(255,255,255,0.08); padding: 6rpx 18rpx; border-radius: 60rpx;
}
.trip-card-title {
  font-size: 44rpx; font-weight: 800; color: #FFF; letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
  margin-bottom: 10rpx; line-height: 1.15;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.trip-card-meta { display: flex; gap: 18rpx; margin-bottom: 12rpx; }
.trip-meta-item { font-size: 22rpx; color: rgba(255,255,255,0.6); font-weight: 500; }
.trip-card-preview { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 12rpx; }
.trip-preview-tag {
  font-size: 20rpx; color: rgba(255,255,255,0.75);
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  padding: 8rpx 18rpx; border-radius: 60rpx;
  max-width: 220rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}

.trip-countdown-badge {
  position: absolute; top: 22rpx; right: 22rpx; z-index: 10;
  display: flex; align-items: baseline; gap: 4rpx;
  background: rgba(255,255,255,0.88);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  padding: 8rpx 24rpx; border-radius: 60rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}
.cd-num { font-size: 42rpx; font-weight: 800; color: #E8A87C; line-height: 1; }
.cd-unit { font-size: 22rpx; color: var(--text-secondary); font-weight: 600; }
.trip-countdown-badge.is-past {
  background: rgba(255,255,255,0.7); font-size: 22rpx; color: var(--muted); padding: 8rpx 20rpx;
}
