/* weather-panel */

.weather-row { display: flex; flex-direction: column; align-items: center; padding: 28rpx 0 0; }
.weather-loading { display: flex; align-items: center; justify-content: center; padding: 56rpx; color: var(--muted); font-size: 26rpx; letter-spacing: 2rpx; }
.weather-error { display: flex; align-items: center; justify-content: center; padding: 48rpx; color: var(--muted); font-size: 26rpx; }

.weather-box {
  background: var(--card-glass); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-radius: 28rpx; padding: 36rpx 40rpx;
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: var(--shadow-card);
  display: flex; align-items: center; gap: 32rpx;
  width: 100%; max-width: 680rpx;
  transition: all 0.3s ease-out;
}
.weather-box:active { transform: scale(0.98); }
.w-icon { font-size: 80rpx; line-height: 1; flex-shrink: 0; }
.w-main { flex: 1; min-width: 0; }
.w-temp { font-weight: 800; font-size: 48rpx; color: var(--text); line-height: 1.1; }
.w-desc { font-size: 28rpx; color: var(--muted); }
.w-extra { text-align: right; flex-shrink: 0; }
.w-hum { font-size: 24rpx; color: var(--muted); }
.w-hint { font-size: 22rpx; color: var(--muted); margin-top: 10rpx; opacity: 0.35; }

.weather-fc { display: flex; gap: 18rpx; padding: 28rpx 20rpx 8rpx; white-space: nowrap; width: 100%; max-width: 700rpx; }
.fc-day {
  flex: 0 0 auto; display: inline-flex; flex-direction: column; align-items: center;
  min-width: 160rpx; padding: 28rpx 18rpx; border-radius: 28rpx;
  background: var(--card-glass); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: var(--shadow-card);
  transition: all 0.25s ease-out;
}
.fc-day:active { transform: translateY(-4rpx); box-shadow: var(--shadow-md); }
.fc-day.today { background: linear-gradient(160deg, #FCFAF6, #F8F4EA); box-shadow: 0 4rpx 20rpx rgba(196,155,138,0.1); }
.fc-day.selected { background: linear-gradient(160deg, #F5F9F6, #ECF3ED); box-shadow: 0 4rpx 20rpx rgba(123,163,138,0.12); transform: translateY(-4rpx); }
.fc-dow { font-size: 26rpx; font-weight: 700; color: var(--text); }
.fc-date { font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }
.fc-icon { font-size: 64rpx; margin: 18rpx 0 12rpx; display: block; line-height: 1; }
.fc-temp { font-size: 28rpx; font-weight: 700; color: var(--text); }
.fc-desc { font-size: 22rpx; color: var(--muted); margin-top: 6rpx; }
.fc-hint { font-size: 20rpx; color: var(--muted); margin-top: 10rpx; }

.hourly-panel { display: flex; gap: 12rpx; padding: 18rpx 20rpx 8rpx; white-space: nowrap; width: 100%; max-width: 700rpx; }
.hr-card {
  flex: 0 0 auto; display: inline-flex; flex-direction: column; align-items: center;
  min-width: 128rpx; padding: 22rpx 10rpx; border-radius: 24rpx;
  background: var(--card-glass); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: var(--shadow-card);
  transition: all 0.25s ease-out;
}
.hr-card.now-hr { background: linear-gradient(160deg, #FCFAF6, #F8F4EA); box-shadow: 0 4rpx 16rpx rgba(196,155,138,0.1); }
.hr-time { font-size: 24rpx; font-weight: 700; color: var(--text); }
.hr-icon { font-size: 44rpx; margin: 10rpx 0 6rpx; display: block; line-height: 1; }
.hr-temp { font-size: 28rpx; font-weight: 700; color: var(--text); }
.hr-desc { font-size: 20rpx; color: var(--muted); margin-top: 2rpx; }
.hr-rain { font-size: 20rpx; color: #8BA4B8; margin-top: 2rpx; }
