/* Trippo 首页 — 轻透玻璃感 */

.page-index {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 100rpx;
}

.header {
  display: flex; align-items: center; gap: 20rpx;
  padding: 80rpx 48rpx 24rpx;
}
.logo-mark {
  width: 72rpx; height: 72rpx;
  border-radius: 22rpx;
  background: #6DB58A;
  box-shadow: 0 4rpx 16rpx rgba(109,181,138,0.2);
  position: relative;
}
.logo-mark::after {
  content: '';
  position: absolute; top: 50%; left: 50%;
  width: 22rpx; height: 22rpx;
  border: 3rpx solid rgba(255,255,255,0.85);
  border-radius: 50%;
  transform: translate(-50%,-50%);
}
.header-text { display: flex; flex-direction: column; }
.header-title { font-size: 44rpx; font-weight: 800; color: var(--text); letter-spacing: 1rpx; }
.header-sub { font-size: 24rpx; color: var(--muted); margin-top: 4rpx; letter-spacing: 1rpx; }

/* 按钮 */
.action-bar { display: flex; gap: 16rpx; padding: 20rpx 48rpx 44rpx; }
.ab-new {
  flex: 1.5;
  display: flex; align-items: center; justify-content: center;
  background: #6DB58A;
  color: #FFF; font-size: 28rpx; font-weight: 600;
  padding: 24rpx 0; border-radius: 60rpx; border: none;
  letter-spacing: 1rpx;
  box-shadow: 0 4rpx 16rpx rgba(109,181,138,0.2);
  transition: all 0.25s ease-out;
}
.ab-new:active { opacity: 0.85; transform: scale(0.96); }
.ab-import {
  flex: 1;
  display: flex; align-items: center; justify-content: center;
  background: var(--card-glass);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  color: var(--text-secondary); font-size: 26rpx; font-weight: 600;
  padding: 24rpx 0; border-radius: 60rpx; border: 1rpx solid rgba(255,255,255,0.6);
  transition: all 0.25s ease-out;
}
.ab-import:active { background: rgba(255,255,255,0.85); transform: scale(0.96); }

/* 骨架 */
.skeleton-list { padding: 0 48rpx; }
.sk-card {
  background: var(--card-glass);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-radius: 28rpx; overflow: hidden;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: var(--shadow-card);
}
.sk-img { width: 100%; height: 440rpx; }
.sk-body { padding: 32rpx; }
.sk-title { height: 36rpx; width: 50%; margin-bottom: 18rpx; }
.sk-line { height: 24rpx; margin-bottom: 22rpx; }
.sk-tags { display: flex; gap: 12rpx; }
.sk-tag { width: 100rpx; height: 34rpx; border-radius: 34rpx; }

/* 空状态 */
.empty-area {
  display: flex; flex-direction: column; align-items: center;
  padding: 120rpx 64rpx 60rpx; text-align: center;
}
.empty-art {
  width: 180rpx; height: 180rpx; margin-bottom: 56rpx;
  position: relative;
  display: flex; align-items: center; justify-content: center;
}
.ea-ring {
  width: 130rpx; height: 130rpx; border-radius: 50%;
  border: 2rpx solid rgba(109,181,138,0.15);
  animation: ea-breathe 3s ease-in-out infinite;
}
@keyframes ea-breathe {
  0%,100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.06); opacity: 0.9; }
}
.ea-dot {
  position: absolute; width: 14rpx; height: 14rpx;
  border-radius: 50%; background: #E8A87C;
}
.ea-d1 { top: 28rpx; left: 50%; margin-left: -7rpx; animation: ea-float 3s ease-in-out infinite; }
.ea-d2 { bottom: 36rpx; right: 38rpx; animation: ea-float 3.5s ease-in-out 0.5s infinite; }
@keyframes ea-float {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-18rpx); }
}
.empty-title { font-size: 36rpx; font-weight: 700; color: var(--text); margin-bottom: 18rpx; }
.empty-desc { font-size: 26rpx; color: var(--muted); line-height: 1.9; max-width: 520rpx; }
.empty-cta { margin-top: 52rpx; }
.empty-cta .btn-primary { font-size: 30rpx; padding: 24rpx 64rpx; }
.empty-link { margin-top: 36rpx; font-size: 26rpx; color: var(--coral); font-weight: 500; }

/* 列表 */
.trip-list { padding: 0 48rpx; }
.trip-item-wrap { margin-bottom: 32rpx; }
.list-end {
  text-align: center; padding: 48rpx 0 80rpx;
  font-size: 26rpx; color: var(--muted); letter-spacing: 2rpx;
}
