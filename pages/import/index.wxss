/* ═══════════════════════════════════════════════
   从帖子导入页样式 — Ins风 · 高级感
   ═══════════════════════════════════════════════ */

.page-import {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 160rpx;
}

/* ── Hero ── */
.import-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 48rpx;
  text-align: center;
}

.ih-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text);
  letter-spacing: 2rpx;
}

.ih-desc {
  font-size: 26rpx;
  color: var(--muted);
  margin-top: 16rpx;
  line-height: 1.7;
  max-width: 480rpx;
  opacity: 0.7;
}

.ih-quota {
  display: inline-block;
  margin-top: 24rpx;
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}

/* ── 剪贴板检测卡片 ── */
.clipboard-card {
  margin: 0 40rpx 32rpx;
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.clip-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.clip-emoji { font-size: 32rpx; }

.clip-title {
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text);
}

.clip-dismiss {
  font-size: 28rpx;
  color: var(--muted);
  padding: 8rpx;
  opacity: 0.5;
}

.clip-url {
  display: block;
  font-size: 22rpx;
  color: var(--muted);
  background: rgba(255,255,255,0.6);
  padding: 14rpx 20rpx;
  border-radius: 16rpx;
  word-break: break-all;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.clip-btn {
  width: 100% !important;
  padding: 22rpx !important;
  font-size: 28rpx !important;
  background: var(--emerald) !important;
  color: #FFF !important;
  border-radius: 20rpx !important;
  font-weight: 600 !important;
  letter-spacing: 2rpx !important;
}

/* ── 模式切换 ── */
.mode-tabs {
  display: flex;
  margin: 0 40rpx 32rpx;
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 6rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--muted);
  border-radius: 20rpx;
  transition: all 0.25s ease;
}

.mode-tab.active {
  background: #FFF;
  color: var(--text);
  font-weight: 700;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* ── 输入区域 ── */
.input-area {
  margin: 0 40rpx;
}

.input-label {
  display: block;
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.url-input, .text-input {
  width: 100%;
  min-height: 220rpx;
  padding: 28rpx 32rpx;
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.8;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-sizing: border-box;
}

.text-input {
  min-height: 340rpx;
}

.input-hint {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: var(--muted);
  line-height: 1.6;
  opacity: 0.6;
}

/* ── 解析按钮 ── */
.btn-parse {
  display: block;
  margin: 40rpx 40rpx;
  padding: 24rpx;
  background: var(--emerald);
  color: #FFF;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border-radius: 20rpx;
  border: none;
  letter-spacing: 2rpx;
  transition: all 0.2s;
}

.btn-parse:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ── 解析中动画 ── */
.parse-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 60rpx;
  text-align: center;
}

.parse-animation {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 48rpx;
}

.pa-dots {
  display: flex;
  gap: 20rpx;
}

.pa-dot {
  width: 14rpx;
  height: 14rpx;
  background: var(--emerald);
  border-radius: 50%;
  animation: dotPulse 1.4s ease infinite;
}

.pa-dot:nth-child(2) { animation-delay: 0.2s; }
.pa-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0.5); opacity: 0.25; }
  40% { transform: scale(1); opacity: 1; }
}

.pa-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: 2rpx;
}

.pa-sub {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 12rpx;
  opacity: 0.6;
}

/* ── 错误 ── */
.error-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 60rpx;
  text-align: center;
}

.es-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 12rpx;
}

.es-desc {
  font-size: 26rpx;
  color: var(--muted);
  line-height: 1.6;
  max-width: 480rpx;
  opacity: 0.7;
}

.es-actions {
  margin-top: 48rpx;
  display: flex;
  gap: 16rpx;
}

.es-actions .btn-secondary {
  padding: 24rpx 48rpx;
  background: #FFF;
  color: var(--text);
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

/* ── 预览 ── */
.preview-header {
  text-align: center;
  padding: 56rpx 48rpx 40rpx;
}

.ph-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text);
  letter-spacing: 2rpx;
}

.ph-stats {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--emerald);
  font-weight: 600;
  opacity: 0.8;
}

.ph-quota {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--muted);
  opacity: 0.5;
}

/* ── 预览卡片 ── */
.preview-card {
  margin: 0 40rpx 24rpx;
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.02), 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.pc-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  display: flex;
  justify-content: space-between;
  align-items: center;
  letter-spacing: 1rpx;
}

.pc-toggle {
  font-size: 22rpx;
  color: var(--muted);
  font-weight: 500;
  opacity: 0.6;
}

.pc-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.pc-row:last-child { border-bottom: none; }

.pc-label {
  font-size: 26rpx;
  color: var(--muted);
  width: 120rpx;
  flex-shrink: 0;
}

.pc-value {
  font-size: 26rpx;
  color: var(--text);
  font-weight: 600;
}

.pc-hint {
  font-size: 24rpx;
  color: var(--muted);
  text-align: center;
  padding: 20rpx 0 4rpx;
  opacity: 0.5;
}

/* ── 行程预览 ── */
.pv-day {
  margin-top: 24rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.pv-day:last-child { border-bottom: none; }

.pv-day-header {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--emerald);
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
  opacity: 0.85;
}

.pv-act {
  display: flex;
  gap: 20rpx;
  padding: 14rpx 0;
  padding-left: 16rpx;
}

.pv-act-time {
  font-size: 24rpx;
  color: var(--gold);
  font-weight: 700;
  width: 80rpx;
  flex-shrink: 0;
  opacity: 0.8;
}

.pv-act-info { flex: 1; min-width: 0; }

.pv-act-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text);
  line-height: 1.4;
}

.pv-act-sub {
  display: block;
  font-size: 23rpx;
  color: var(--muted);
  margin-top: 4rpx;
  opacity: 0.7;
}

.pv-act-detail {
  display: block;
  font-size: 22rpx;
  color: var(--muted);
  opacity: 0.55;
  margin-top: 4rpx;
  line-height: 1.5;
}

/* ── 餐厅预览 ── */
.pv-resto {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--text);
}

.pv-resto-meta {
  color: var(--muted);
  font-size: 24rpx;
  opacity: 0.7;
}

/* ── 贴士完整预览 ── */
.pv-tip-full {
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}
.pv-tip-full:last-child { border-bottom: none; }
.pv-tip-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}
.pv-tip-body {
  display: block;
  font-size: 24rpx;
  color: var(--muted);
  line-height: 1.7;
  padding-left: 12rpx;
  opacity: 0.75;
}

/* ── 常用语预览 ── */
.pv-phrase {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}
.pv-phrase:last-child { border-bottom: none; }
.pv-phrase-local {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  flex: 1;
}
.pv-phrase-pron {
  font-size: 24rpx;
  color: var(--muted);
  font-style: italic;
  opacity: 0.7;
}
.pv-phrase-zh {
  font-size: 26rpx;
  color: var(--gold);
  font-weight: 600;
}

/* ── 伴手礼预览 ── */
.pv-souv {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}
.pv-souv:last-child { border-bottom: none; }
.pv-souv-emoji { font-size: 48rpx; flex-shrink: 0; }
.pv-souv-info { flex: 1; min-width: 0; }
.pv-souv-name {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text);
}
.pv-souv-meta {
  display: block;
  font-size: 23rpx;
  color: var(--muted);
  margin-top: 4rpx;
  opacity: 0.7;
}
.pv-souv-desc {
  display: block;
  font-size: 22rpx;
  color: var(--muted);
  opacity: 0.55;
  margin-top: 4rpx;
  line-height: 1.5;
}

/* ── 底部操作栏 ── */
.preview-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx 40rpx;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.03);
  z-index: 100;
}

.preview-bottom .btn-secondary {
  padding: 22rpx 0;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  text-align: center;
  background: rgba(255,255,255,0.5);
  color: var(--text);
  letter-spacing: 1rpx;
}

.preview-bottom .btn-accent {
  padding: 22rpx 0;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: 1rpx solid var(--emerald);
  text-align: center;
  background: transparent;
  color: var(--emerald);
  letter-spacing: 1rpx;
}

.preview-bottom .btn-primary {
  padding: 22rpx 0;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  text-align: center;
  background: var(--emerald);
  color: #FFF;
  letter-spacing: 1rpx;
}
