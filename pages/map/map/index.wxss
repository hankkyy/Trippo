/* ═══════════════════════════════════════════════
   地图页样式
   <map> 是原生组件，覆盖层必须用 cover-view
   ═══════════════════════════════════════════════ */

.map-page {
  width: 100%;
  height: 100vh;
  position: relative;
  background: var(--bg);
}

.trip-map {
  width: 100%;
  height: 100%;
}

/* ── 加载 / 错误 ── */
.map-loading,
.map-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  gap: 24rpx;
  color: var(--muted);
  font-size: 28rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid #EDEAE2;
  border-top-color: var(--gold);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.me-icon { font-size: 100rpx; }
.me-title { font-size: 34rpx; font-weight: 700; color: var(--text); }
.me-desc { font-size: 26rpx; color: var(--muted); }

/* ── 分类筛选栏（cover-view） ── */
.filter-bar {
  position: fixed;
  top: 16rpx;
  left: 0;
  right: 0;
  z-index: 10;
  padding: 0 24rpx;
}

.filter-scroll {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 8rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  border-radius: 50rpx;
  background: rgba(255, 255, 255, 0.95);
  color: var(--text);
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  white-space: nowrap;
}

.filter-chip.active {
  background: var(--emerald);
  color: #FFF;
  box-shadow: 0 4rpx 20rpx rgba(26, 107, 74, 0.3);
}

/* ── 底部 popup（cover-view） ── */
.map-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: #FFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 32rpx 48rpx;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.15);
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

.map-popup.show {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.popup-emoji { font-size: 48rpx; }

.popup-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text);
}

.popup-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F1F0EB;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--muted);
}

.popup-desc {
  font-size: 28rpx;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.popup-actions {
  display: flex;
  gap: 16rpx;
}

.popup-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  background: var(--emerald);
  color: #FFF;
  border-radius: var(--radius);
  font-size: 28rpx;
  font-weight: 700;
}

/* ── 图例提示 ── */
.map-legend {
  position: fixed;
  bottom: 48rpx;
  left: 0;
  right: 0;
  z-index: 5;
  text-align: center;
  pointer-events: none;
  padding-bottom: env(safe-area-inset-bottom);
}

.legend-text {
  display: inline-block;
  background: rgba(0, 0, 0, 0.65);
  color: #FFF;
  padding: 10rpx 28rpx;
  border-radius: 50rpx;
  font-size: 22rpx;
}
