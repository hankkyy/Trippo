/* ═══════════════════════════════════════════════
   模板库列表页样式
   ═══════════════════════════════════════════════ */

.page-templates {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 40rpx;
}

/* ── 分类 Tab ── */
.category-tabs {
  display: flex;
  white-space: nowrap;
  padding: 20rpx 24rpx;
  background: var(--card);
  border-bottom: 1rpx solid #F0EDE8;
  position: sticky;
  top: 0;
  z-index: 10;
}

.ct-tab {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--muted);
  background: #F5F2EB;
  margin-right: 16rpx;
  transition: all 0.2s;
  flex-shrink: 0;
}

.ct-tab.active {
  background: var(--emerald);
  color: #FFF;
}

/* ── 加载 ── */
.tg-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx;
  color: var(--muted);
  font-size: 28rpx;
  gap: 24rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid #EDEAE2;
  border-top-color: var(--gold);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ── 卡片网格 ── */
.tpl-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 24rpx;
}

.tpl-card {
  background: var(--card);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s;
}

.tpl-card-hover {
  transform: scale(0.96);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.tpl-cover {
  width: 100%;
  height: 240rpx;
  background: #D1CBB8;
}

.tpl-content {
  padding: 20rpx;
}

.tpl-category-tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 50rpx;
  background: var(--emerald-light);
  color: var(--emerald);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.tpl-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
  line-height: 1.3;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tpl-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--muted);
}
