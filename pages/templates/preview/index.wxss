/* ═══════════════════════════════════════════════
   模板预览页样式
   ═══════════════════════════════════════════════ */

.page-preview {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 160rpx;
}

/* ── 加载/错误 ── */
.pv-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx;
  color: var(--muted);
  gap: 24rpx;
  font-size: 28rpx;
}

.loading-spinner {
  width: 56rpx; height: 56rpx;
  border: 6rpx solid #EDEAE2;
  border-top-color: var(--gold);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.pv-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 60rpx;
  text-align: center;
}
.pe-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.pe-title { font-size: 34rpx; font-weight: 700; color: var(--text); margin-bottom: 12rpx; }
.pe-desc { font-size: 26rpx; color: var(--muted); }

/* ── Hero ── */
.pv-hero {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}
.pv-cover {
  width: 100%;
  height: 100%;
  opacity: 0.7;
}
.pv-hero-overlay {
  position: absolute; inset: 0;
}
.pv-hero-content {
  position: absolute; bottom: 40rpx; left: 32rpx; right: 32rpx;
  color: #FFF; z-index: 2;
}
.pv-category {
  display: inline-block; font-size: 22rpx; padding: 6rpx 16rpx;
  border-radius: 50rpx; background: rgba(255,255,255,0.2);
  margin-bottom: 12rpx;
}
.pv-title { font-size: 44rpx; font-weight: 900; line-height: 1.2; margin-bottom: 8rpx; }
.pv-meta { display: flex; gap: 16rpx; font-size: 24rpx; opacity: 0.85; }

/* ── 内容 ── */
.pv-body { padding: 24rpx 28rpx; }

.pv-section {
  background: var(--card); border-radius: var(--radius);
  padding: 24rpx 28rpx; margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.pv-section-title {
  font-size: 28rpx; font-weight: 700; color: var(--text); margin-bottom: 16rpx;
}

.pv-day-item {
  display: flex; gap: 16rpx; align-items: center;
  padding: 16rpx 0; border-bottom: 1rpx solid #F0EDE5;
}
.pv-day-item:last-child { border-bottom: none; }
.pv-day-num {
  font-size: 24rpx; font-weight: 900; color: #FFF;
  background: var(--emerald); padding: 8rpx 20rpx; border-radius: 50rpx;
  flex-shrink: 0;
}
.pv-day-info { flex: 1; min-width: 0; }
.pv-day-theme { font-size: 26rpx; font-weight: 600; color: var(--text); }
.pv-day-count { font-size: 22rpx; color: var(--muted); margin-top: 4rpx; }

.pv-resto-item {
  display: flex; justify-content: space-between;
  padding: 14rpx 0; border-bottom: 1rpx solid #F0EDE5;
  font-size: 26rpx;
}
.pv-resto-item:last-child { border-bottom: none; }
.pv-resto-price { color: var(--muted); font-size: 24rpx; }

.pv-tip-item {
  padding: 12rpx 0; border-bottom: 1rpx solid #F0EDE5;
  font-size: 26rpx; color: var(--text);
}
.pv-tip-item:last-child { border-bottom: none; }

/* ── 底部按钮 ── */
.pv-bottom {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 28rpx;
  background: rgba(255,255,255,0.96);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0,0,0,0.06);
  z-index: 100;
}
.pv-use-btn { width: 100%; }
