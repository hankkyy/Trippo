/* ═══════════════════════════════════════════════
   餐厅编辑器样式
   ═══════════════════════════════════════════════ */

.page-restos {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 160rpx;
}

/* ── 加载 / 错误 ── */
.detail-loading,
.detail-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 60rpx;
  gap: 24rpx;
  color: var(--muted);
  font-size: 28rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid #EDEAE2;
  border-top-color: var(--gold);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.de-icon { font-size: 100rpx; }
.de-title { font-size: 34rpx; font-weight: 700; color: var(--text); }
.de-desc { font-size: 26rpx; color: var(--muted); }

/* ── 餐厅列表 ── */
.resto-list {
  padding: 32rpx 40rpx;
}

.resto-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.35);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.02), 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s;
}

.resto-card:active {
  transform: scale(0.98);
  background: var(--gold-light);
}

.rc-emoji { font-size: 52rpx; flex-shrink: 0; }

.rc-info {
  flex: 1;
  min-width: 0;
}

.rc-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.rc-meta {
  display: block;
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 4rpx;
}

.rc-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 10rpx;
}

.rc-arrow {
  font-size: 36rpx;
  color: var(--muted);
  flex-shrink: 0;
}

/* ── 空状态 ── */
.empty-restos {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; opacity: 0.6; }
.empty-text { font-size: 28rpx; color: var(--muted); }
.empty-hint { font-size: 24rpx; color: var(--muted); opacity: 0.6; margin-top: 8rpx; }

/* ── 底部按钮 ── */
.bottom-add-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  z-index: 50;
}

.btn-add {
  width: 100%;
  padding: 28rpx;
  border: 1.5rpx dashed rgba(0, 0, 0, 0.12);
  border-radius: 24rpx;
  background: transparent;
  color: var(--muted);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ── 表单弹窗 ── */
.form-overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.form-panel {
  width: 100%;
  background: #FFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 44rpx 40rpx 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  max-height: 85vh;
  overflow-y: auto;
}

.form-title {
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 32rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--muted);
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid #E5E0D5;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #FAFAF8;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #E5E0D5;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #FAFAF8;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

/* ── 标签选择器 ── */
.tag-selector {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tag-chip {
  padding: 14rpx 28rpx;
  border-radius: 50rpx;
  border: 2rpx solid #E5E0D5;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--muted);
  background: #FFF;
  transition: all 0.2s;
}

.tag-chip.selected {
  color: var(--emerald);
  border-color: var(--emerald);
  background: var(--emerald-light);
}

/* ── 操作按钮 ── */
.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.btn-cancel {
  flex: 1;
  padding: 24rpx;
  background: #F1F0EB;
  border-radius: var(--radius);
  font-size: 28rpx;
  font-weight: 600;
  color: var(--muted);
  border: none;
}

.btn-save {
  flex: 1;
  padding: 24rpx;
  background: var(--emerald);
  border-radius: var(--radius);
  font-size: 28rpx;
  font-weight: 700;
  color: #FFF;
  border: none;
}
