/* 编辑页 */

.page-edit {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 180rpx;
}
.edit-scroll { height: calc(100vh - 20rpx); }

.fs-card {
  margin: 22rpx 36rpx;
  background: var(--card-glass);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-radius: 28rpx; overflow: hidden;
  border: 1rpx solid rgba(255,255,255,0.6);
  box-shadow: var(--shadow-card);
  transition: box-shadow 0.3s ease-out;
}
.fs-card.fs-open { box-shadow: var(--shadow-md); }

.fs-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 36rpx 32rpx;
}
.fs-header-left { display: flex; align-items: center; gap: 16rpx; }
.fs-header-right { display: flex; align-items: center; gap: 14rpx; }
.fs-dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: #E8A87C; flex-shrink: 0; }
.fs-dot.flight { background: #8BA4B8; }
.fs-dot.hotel { background: #C49B9B; }
.fs-dot.budget { background: #E0C068; }
.fs-dot.done { background: #6DB58A; }
.fs-label { font-size: 30rpx; font-weight: 700; color: var(--text); letter-spacing: 1rpx; }
.fs-done-badge { font-size: 22rpx; font-weight: 700; color: #6DB58A; background: rgba(109,181,138,0.08); padding: 4rpx 16rpx; border-radius: 60rpx; }

.fs-arrow {
  width: 20rpx; height: 20rpx;
  border-right: 3rpx solid var(--muted); border-bottom: 3rpx solid var(--muted);
  transform: rotate(45deg); transition: transform 0.25s ease-out; opacity: 0.4;
}
.fs-arrow.open { transform: rotate(-135deg); }
.fs-body { padding: 0 32rpx 32rpx; }

.fs-subheader {
  font-size: 24rpx; font-weight: 700; color: var(--coral); letter-spacing: 3rpx;
  margin-bottom: 28rpx; padding-bottom: 18rpx;
  border-bottom: 2rpx solid rgba(212,171,154,0.1);
}

.fg-item { margin-bottom: 24rpx; }
.fg-row { display: flex; gap: 20rpx; }
.fg-half { flex: 1; }
.fg-label { display: block; font-size: 24rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 12rpx; letter-spacing: 2rpx; }
.fg-label.required::after { content: ' *'; color: #D49292; font-weight: 400; }

.fg-input {
  width: 100%; padding: 24rpx 28rpx;
  border: 2rpx solid #E8E4DC; border-radius: 22rpx;
  font-size: 28rpx; color: var(--text); background: rgba(255,255,255,0.5);
  letter-spacing: 0.5rpx; transition: border-color 0.2s;
}
.fg-input:focus { border-color: var(--coral); background: #FFF; }
.fg-input::placeholder { color: #B5AFA6; }

.fg-picker { padding: 24rpx 28rpx; border: 2rpx solid #E8E4DC; border-radius: 22rpx; font-size: 28rpx; color: var(--text); background: rgba(255,255,255,0.5); }
.fg-picker.placeholder { color: #B5AFA6; }

.fg-input-with-unit {
  display: flex; align-items: center; border: 2rpx solid #E8E4DC;
  border-radius: 22rpx; background: rgba(255,255,255,0.5); overflow: hidden;
}
.fg-input-with-unit:focus-within { border-color: var(--coral); background: #FFF; }
.fg-unit { padding: 24rpx 0 24rpx 28rpx; font-size: 28rpx; font-weight: 700; color: var(--text-secondary); flex-shrink: 0; }
.fg-input-unit { flex: 1; padding: 24rpx 28rpx 24rpx 12rpx; border: none; font-size: 28rpx; color: var(--text); background: transparent; }

.theme-picker { display: flex; gap: 14rpx; }
.theme-chip {
  display: flex; align-items: center; gap: 10rpx;
  padding: 20rpx 32rpx; border-radius: 60rpx;
  background: rgba(255,255,255,0.5); border: 2rpx solid transparent;
  font-size: 24rpx; color: var(--text-secondary); font-weight: 500; letter-spacing: 1rpx;
  transition: all 0.25s ease-out;
}
.theme-chip.active { border-color: var(--coral); background: rgba(212,171,154,0.06); color: var(--coral); font-weight: 700; }
.tc-dot { width: 36rpx; height: 36rpx; border-radius: 50%; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1); flex-shrink: 0; }

.edit-bottom {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; gap: 20rpx;
  padding: 24rpx 36rpx;
  background: rgba(249,248,245,0.85);
  backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(0,0,0,0.03);
  z-index: 100;
}
.edit-bottom .btn-primary { flex: 1; font-size: 30rpx; padding: 28rpx 0; }
