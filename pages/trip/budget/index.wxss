/* ═══════════════════════════════════════════════
   记账本样式
   ═══════════════════════════════════════════════ */

.page-budget {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 160rpx;
}
.detail-loading, .detail-error {
  display: flex; flex-direction: column; align-items: center;
  padding: 200rpx 60rpx; gap: 28rpx;
  color: var(--muted); font-size: 26rpx;
}
.loading-spinner {
  width: 48rpx; height: 48rpx;
  border: 4rpx solid #EBE5DC;
  border-top-color: var(--terracotta);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.de-title { font-size: 34rpx; font-weight: 700; color: var(--text); }
.de-desc { font-size: 26rpx; color: var(--muted); }

@keyframes spin { to { transform: rotate(360deg); } }

.de-icon { font-size: 100rpx; }
.de-title { font-size: 34rpx; font-weight: 700; color: var(--text); }
.de-desc { font-size: 26rpx; color: var(--muted); }

/* ── 汇总卡片 ── */
.summary-card {
  margin: 36rpx 40rpx;
  padding: 40rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(123,163,138,0.06);
  box-shadow: var(--shadow-card);
}
.sum-row { display: flex; justify-content: space-between; align-items: center; padding: 8rpx 0; }
.sum-row.main {
  padding: 16rpx 0;
  border-bottom: 2rpx solid rgba(125,155,118,0.1);
  margin-bottom: 14rpx;
}
.sum-row.diff { margin-bottom: 18rpx; }
.sum-label { font-size: 26rpx; color: var(--muted); }
.sum-value { font-size: 42rpx; font-weight: 800; color: var(--green); }
.sum-value.sub { font-size: 28rpx; font-weight: 600; }
.sum-value.over { color: #C46B7A; }
.sum-value.safe { color: var(--green); }
.sum-meta {
  display: flex; justify-content: space-between;
  margin-top: 18rpx; font-size: 22rpx; color: var(--muted);
}

.progress-bar {
  height: 12rpx; background: rgba(0,0,0,0.05);
  border-radius: 6rpx; overflow: hidden; margin-top: 8rpx;
}
.progress-fill {
  height: 100%; background: var(--green);
  border-radius: 6rpx; transition: width 0.5s ease-out;
}
.progress-fill.over { background: #C46B7A; }
.progress-label {
  display: block; font-size: 22rpx;
  color: var(--muted); text-align: right; margin-top: 8rpx;
}

/* ── 花费列表 ── */
.expense-list {
  padding: 0 40rpx;
}

.expense-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 28rpx;
  background: var(--card-glass); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border-radius: 22rpx; margin-bottom: 12rpx;
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: var(--shadow-card);
  transition: all 0.2s ease-out;
}
.expense-item:active { box-shadow: var(--shadow-md); }

.ei-left {
  flex: 1;
  min-width: 0;
}

.ei-desc {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.ei-meta {
  display: block;
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 4rpx;
}

.ei-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.ei-rmb {
  font-size: 26rpx; font-weight: 700;
  color: var(--green);
}

.ei-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #DC2626;
  font-size: 28rpx;
  font-weight: 700;
}

/* ── 空状态 ── */
.empty-expenses {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx 80rpx;
  text-align: center;
}

.empty-ring {
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(200,151,74,0.18);
  margin-bottom: 32rpx;
  position: relative;
}
.empty-ring::after {
  content: '';
  position: absolute;
  top: 50%; left: 50%;
  width: 32rpx; height: 3rpx;
  background: rgba(200,151,74,0.5);
  border-radius: 2rpx;
  transform: translate(-50%, -50%) rotate(-30deg);
}

.empty-expenses .empty-text {
  font-size: 30rpx; font-weight: 700;
  color: var(--text); margin-bottom: 12rpx;
}
.empty-expenses .empty-hint {
  font-size: 26rpx; color: var(--muted); opacity: 0.6;
}

/* ── 底部添加按钮 ── */
.bottom-add-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.03);
  z-index: 50;
}

.btn-add {
  width: 100%;
  padding: 28rpx;
  border: 2rpx dashed rgba(0, 0, 0, 0.1);
  border-radius: 20rpx;
  background: transparent;
  color: var(--muted);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
}

.btn-add:active {
  border-color: var(--gold);
  color: var(--gold);
  background: rgba(200, 151, 74, 0.04);
}

/* ── 表单弹窗 ── */
.form-overlay {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.form-panel {
  width: 100%;
  background: #FFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 44rpx 40rpx 48rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  overflow-y: auto;
}

.form-title {
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 32rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--muted);
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 2rpx solid #E5E0D5;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #FAFAF8;
}

.form-picker {
  padding: 20rpx 24rpx;
  border: 2rpx solid #E5E0D5;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #FAFAF8;
  color: var(--text);
}

.form-row {
  display: flex;
  gap: 16rpx;
}

/* ── 分摊切换 ── */
.split-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.split-btn {
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  border: 2rpx solid #E5E0D5;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--muted);
  background: #FFF;
  transition: all 0.2s;
}

.split-btn.active {
  background: var(--terracotta);
  color: #FFF;
  border-color: var(--terracotta);
}

.people-input {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: var(--muted);
}

.people-input input {
  width: 80rpx;
  padding: 12rpx 8rpx;
  border: 2rpx solid #E5E0D5;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
}

/* ── 表单操作按钮 ── */
.form-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.btn-cancel {
  flex: 1;
  padding: 24rpx;
  background: #F1F0EB;
  border-radius: var(--radius);
  font-size: 28rpx;
  font-weight: 600;
  color: var(--muted);
  border: none;
}

.btn-save {
  flex: 1;
  padding: 24rpx;
  border-radius: 60rpx;
  font-size: 28rpx; font-weight: 700;
  color: #FFF; border: none;
  box-shadow: 0 4rpx 16rpx rgba(125,155,118,0.2);
}

.btn-delete {
  flex: 1;
  padding: 24rpx;
  background: #DC2626;
  border-radius: var(--radius);
  font-size: 28rpx;
  font-weight: 700;
  color: #FFF;
  border: none;
}

/* ── 删除确认弹窗 ── */
.confirm-dialog {
  width: 100%;
  background: #FFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 32rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  text-align: center;
}

.confirm-title {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.confirm-desc {
  display: block;
  font-size: 26rpx;
  color: var(--muted);
  margin-bottom: 32rpx;
}

.confirm-actions {
  display: flex;
  gap: 16rpx;
}
